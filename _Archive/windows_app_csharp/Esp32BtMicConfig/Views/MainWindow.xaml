<Window x:Class="Esp32BtMicConfig.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:Esp32BtMicConfig.ViewModels"
        xmlns:local="clr-namespace:Esp32BtMicConfig.Views"
        Title="ESP32 BT Mic Config"
        Width="620" Height="720"
        MinWidth="580" MinHeight="680"
        WindowStartupLocation="CenterScreen"
        PreviewKeyDown="Window_PreviewKeyDown"
        KeyboardNavigation.TabNavigation="None"
>

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <local:InvertBoolConverter x:Key="InvertBool"/>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Connection -->
        <GroupBox Grid.Row="0" Header="Connection">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <Button Content="Scan &amp; Connect"
                            Command="{Binding ScanAndConnectCommand}"
                            IsEnabled="{Binding IsScanning, Converter={StaticResource InvertBool}}"
                            Width="130"/>
                    <Button Content="Disconnect"
                            Command="{Binding DisconnectCommand}"
                            IsEnabled="{Binding IsConnected}"
                            Width="100"/>
                    <TextBlock Text="{Binding ConnectionStatusText}" Margin="12,0,0,0"
                               Foreground="Gray"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="HFP:" FontWeight="SemiBold" Width="36"/>
                    <TextBlock Text="{Binding HfpStatusText}" Width="90"/>
                    <TextBlock Text="Audio:" FontWeight="SemiBold" Width="44"/>
                    <TextBlock Text="{Binding AudioStatusText}" Width="90"/>
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Button 1 -->
        <GroupBox Grid.Row="1" Header="Button 1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Key:" Width="36" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Button1KeyName}" Width="100"
                               Background="#FFF0F0F0" Padding="6,2" Margin="0,0,8,0"/>
                    <Button Content="Capture Key"
                            Click="Button1Capture_Click"
                            IsEnabled="{Binding Button1Capturing, Converter={StaticResource InvertBool}}"
                            Width="100"/>
                    <TextBlock Text="Click to capture, then press a key"
                               Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Button1Capturing, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
                <TextBlock Text="Modifiers:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <WrapPanel Margin="16,0,0,0">
                    <CheckBox Content="LCtrl" IsChecked="{Binding Button1ModLCtrl}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="LShift" IsChecked="{Binding Button1ModLShift}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="LAlt" IsChecked="{Binding Button1ModLAlt}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="LWin" IsChecked="{Binding Button1ModLWin}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RCtrl" IsChecked="{Binding Button1ModRCtrl}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RShift" IsChecked="{Binding Button1ModRShift}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RAlt" IsChecked="{Binding Button1ModRAlt}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RWin" IsChecked="{Binding Button1ModRWin}" IsEnabled="{Binding IsConnected}"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <!-- Button 2 -->
        <GroupBox Grid.Row="2" Header="Button 2">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Key:" Width="36" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Button2KeyName}" Width="100"
                               Background="#FFF0F0F0" Padding="6,2" Margin="0,0,8,0"/>
                    <Button Content="Capture Key"
                            Click="Button2Capture_Click"
                            IsEnabled="{Binding Button2Capturing, Converter={StaticResource InvertBool}}"
                            Width="100"/>
                    <TextBlock Text="Click to capture, then press a key"
                               Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Button2Capturing, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
                <TextBlock Text="Modifiers:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <WrapPanel Margin="16,0,0,0">
                    <CheckBox Content="LCtrl" IsChecked="{Binding Button2ModLCtrl}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="LShift" IsChecked="{Binding Button2ModLShift}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="LAlt" IsChecked="{Binding Button2ModLAlt}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="LWin" IsChecked="{Binding Button2ModLWin}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RCtrl" IsChecked="{Binding Button2ModRCtrl}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RShift" IsChecked="{Binding Button2ModRShift}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RAlt" IsChecked="{Binding Button2ModRAlt}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RWin" IsChecked="{Binding Button2ModRWin}" IsEnabled="{Binding IsConnected}"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <!-- Button 3 -->
        <GroupBox Grid.Row="3" Header="Button 3">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                    <TextBlock Text="Key:" Width="36" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding Button3KeyName}" Width="100"
                               Background="#FFF0F0F0" Padding="6,2" Margin="0,0,8,0"/>
                    <Button Content="Capture Key"
                            Click="Button3Capture_Click"
                            IsEnabled="{Binding Button3Capturing, Converter={StaticResource InvertBool}}"
                            Width="100"/>
                    <TextBlock Text="Click to capture, then press a key"
                               Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"
                               Visibility="{Binding Button3Capturing, Converter={StaticResource BoolToVis}}"/>
                </StackPanel>
                <TextBlock Text="Modifiers:" FontWeight="SemiBold" Margin="0,0,0,2"/>
                <WrapPanel Margin="16,0,0,0">
                    <CheckBox Content="LCtrl" IsChecked="{Binding Button3ModLCtrl}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="LShift" IsChecked="{Binding Button3ModLShift}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="LAlt" IsChecked="{Binding Button3ModLAlt}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="LWin" IsChecked="{Binding Button3ModLWin}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RCtrl" IsChecked="{Binding Button3ModRCtrl}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RShift" IsChecked="{Binding Button3ModRShift}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RAlt" IsChecked="{Binding Button3ModRAlt}" IsEnabled="{Binding IsConnected}"/>
                    <CheckBox Content="RWin" IsChecked="{Binding Button3ModRWin}" IsEnabled="{Binding IsConnected}"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>

        <!-- Last Event -->
        <GroupBox Grid.Row="4" Header="Last Button Event">
            <TextBlock Text="{Binding LastEventText}" FontWeight="SemiBold" FontSize="14"/>
        </GroupBox>

        <!-- Action Buttons -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8">
            <Button Content="Write to Device"
                    Command="{Binding SaveToDeviceCommand}"
                    IsEnabled="{Binding IsConnected}"
                    Width="130" Height="32"/>
            <Button Content="Save to File"
                    Command="{Binding SaveConfigFileCommand}"
                    Width="110" Height="32"/>
            <Button Content="Load from File"
                    Command="{Binding LoadConfigFileCommand}"
                    Width="110" Height="32"/>
            <CheckBox Content="开机自动启动"
                      IsChecked="{Binding AutoStart}"
                      VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <!-- Device Settings -->
        <GroupBox Grid.Row="6" Header="Device Settings">
            <StackPanel Orientation="Horizontal" Margin="4">
                <TextBlock Text="TX Power:" FontWeight="SemiBold" VerticalAlignment="Center" Width="70"/>
                <ComboBox Width="120" VerticalAlignment="Center" Margin="0,0,12,0"
                          SelectedIndex="{Binding TxPowerLevel}" IsEnabled="{Binding IsConnected}">
                    <ComboBoxItem Content="0: -12 dBm (min)"/>
                    <ComboBoxItem Content="1: -9 dBm"/>
                    <ComboBoxItem Content="2: -6 dBm"/>
                    <ComboBoxItem Content="3: -3 dBm"/>
                    <ComboBoxItem Content="4: 0 dBm"/>
                    <ComboBoxItem Content="5: +3 dBm"/>
                    <ComboBoxItem Content="6: +6 dBm"/>
                    <ComboBoxItem Content="7: +9 dBm (max)"/>
                </ComboBox>
                <TextBlock Text="Sleep Mode:" FontWeight="SemiBold" VerticalAlignment="Center" Margin="12,0,4,0"/>
                <CheckBox Content="Enabled" IsChecked="{Binding SleepModeEnabled}" IsEnabled="{Binding IsConnected}" VerticalAlignment="Center"/>
                <TextBlock Text="(requires Write to Device)" Foreground="Gray" VerticalAlignment="Center" Margin="8,0,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Log / Info -->
        <GroupBox Grid.Row="7" Header="Info">
            <TextBlock TextWrapping="Wrap" Foreground="Gray" FontSize="11">
                <Run Text="BLE Service UUID: "/><Run Text="0x1820" FontWeight="SemiBold"/><LineBreak/>
                <Run Text="Device Name: "/><Run Text="ESP32_BT_MIC" FontWeight="SemiBold"/><LineBreak/>
                <Run Text="Tip: Click &quot;Capture Key&quot; then press any key on your keyboard to assign it."/><LineBreak/>
                <Run Text="Modifier checkboxes require the device to be connected."/>
            </TextBlock>
        </GroupBox>
    </Grid>
</Window>
